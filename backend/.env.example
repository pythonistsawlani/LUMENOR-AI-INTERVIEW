# Backend Environment Variables
# Copy this file to .env and fill in your real credentials

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hireflow_db?retryWrites=true&w=majority

# Hugging Face API key (get from huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_your_token_here

# AI Model (leave default or change to another instruction-tuned model)
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# JWT Secret - use a long random string in production
JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars

# Allowed CORS origins (comma-separated, no spaces)
# Development: leave as * or set localhost
# Production: set to your Vercel URL
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
